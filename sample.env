# sample.env — copy to .env (or let ./mount.sh create it interactively
# on first run) and fill in your values.

# Dataverse endpoint URL (no trailing slash).
DV_HOST=https://demo.dataverse.org

# Dataverse API token. OPTIONAL — leave blank for guest access to
# public datasets and public files. A token is only needed for
# restricted files, draft versions, or datasets the owner limited to
# authenticated readers. Treat it like a password; never commit it.
DV_TOKEN=

# Persistent ID of the dataset to mount. DOIs use the doi:NNN/PATH form.
DATASET_PID=doi:10.5072/FK2/ABCD

# Optional: dataset version to mount.
#   :latest             — most recent version visible to the token (default)
#   :draft              — draft version (must be the dataset owner)
#   :latest-published   — most recent published version
#   1.0 / 2.0 / etc.    — specific numeric version
# DATASET_VERSION=:latest

# Optional: which form to surface for tabular-ingest files
# (CSV/Stata/SPSS/…). `original` (default) returns the bytes the user
# uploaded plus a verifiable MD5; `archival` returns Dataverse's
# post-ingest .tab form (no size, no MD5 — Dataverse doesn't store
# either reliably for the archival form).
# INGEST_FORMAT=original

# Optional: rclone VFS cache mode. `minimal` is right for read-only
# streaming; `writes` for write-back caching; `full` for full caching.
# VFS_CACHE_MODE=minimal

# Optional: how long the rclone VFS keeps cached file content before
# refetching from Dataverse. Doesn't affect listings.
# VFS_CACHE_MAX_AGE=1h

# Optional: rclone log level (DEBUG | INFO | NOTICE | ERROR).
# RCLONE_LOG_LEVEL=INFO

# Optional: friendly name for the Globus endpoint registered by
# ./mount-globus.sh on first run. Defaults to dataverse-mount-<hostname>.
# GLOBUS_ENDPOINT_NAME=my-dataverse-mount
